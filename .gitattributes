# Normalización de line endings
* text=auto eol=lf

# PHP
*.php text eol=lf
*.blade.php text eol=lf diff=html

# Frontend
*.js text eol=lf
*.css text eol=lf diff=css
*.scss text eol=lf

# Markup / Data
*.html text eol=lf diff=html
*.md text eol=lf diff=markdown
*.json text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Config
*.env text eol=lf
*.ini text eol=lf
.editorconfig text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf

# Shell
*.sh text eol=lf
*.bash text eol=lf

# Binarios (no normalizar)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Export ignore
/.github export-ignore
CHANGELOG.md export-ignore
.styleci.yml export-ignore
